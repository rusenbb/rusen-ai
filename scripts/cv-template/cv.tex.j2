% !TEX TS-program = tectonic
%
% Generated from src/content/cv.json by scripts/render_cv.py.
% Do not edit by hand - edit the JSON and re-run `npm run cv:build`.
%
% Style: neo-brutalist (mono headers, thick black rules, no chrome).
% Mirrors the visual language of rusen.ai/cv.

\documentclass[11pt,a4paper]{article}

% XeTeX-native font setup (tectonic uses XeTeX). TeX Gyre Heros is the
% Helvetica clone with full Latin Extended coverage including Turkish
% (Ş, İ, Ğ, ı). Latin Modern Mono Light for the mono headers - same
% Turkish coverage and a more elegant weight than default Inconsolata.
\usepackage{fontspec}
\setmainfont{TeX Gyre Heros}
\setmonofont{Latin Modern Mono Light}[Scale=MatchLowercase]
\renewcommand{\familydefault}{\sfdefault}

\BLOCK{ if is_cjk }
% CJK setup. xeCJK lets us mix Latin and CJK glyphs in a single document;
% Noto Serif/Sans CJK JP cover the Japanese script range. The Latin fonts
% above stay in charge of ASCII ranges (dates, URLs, mono headers).
\usepackage{xeCJK}
\setCJKmainfont{Noto Serif CJK JP}
\setCJKsansfont{Noto Sans CJK JP}
\setCJKmonofont{Noto Sans Mono CJK JP}
\BLOCK{ endif }

% fontawesome5 segfaults tectonic when combined with the volume of content
% in this CV (reliably reproducible). fontawesome (v4) is rock-solid here
% and covers every glyph we need.
\usepackage{fontawesome}
\usepackage[top=0.6in, bottom=0.55in, left=0.7in, right=0.7in]{geometry}
\usepackage{enumitem}
\usepackage{xcolor}
\usepackage{titlesec}
\usepackage{hyperref}
\usepackage{setspace}
\usepackage{needspace}

\setstretch{1.15}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\raggedright

\hypersetup{
  colorlinks=false,
  pdfborder={0 0 0},
  pdftitle={\VAR{cv.basics.name | latex} CV},
  pdfauthor={\VAR{cv.basics.name | latex}}
}
\pagestyle{empty}

% Section colors
\definecolor{cvsecnum}{HTML}{C0C0C0}
\definecolor{cvrule}{HTML}{111111}

% Custom section command: "01 EXPERIENCE" with a muted number prefix and a
% thick rule under, mirroring the HTML CV's section style. Title content
% is expected to already be uppercased (locale-aware) by the Jinja
% `upper` filter - we don't call \MakeUppercase here because it doesn't
% know about Turkish dotted-i.
\newcounter{cvsec}
\setcounter{cvsec}{0}
\newcommand{\cvsection}[1]{%
  \refstepcounter{cvsec}%
  \needspace{4\baselineskip}%
  \par\vspace{14pt}%
  \noindent%
  {\ttfamily\bfseries\large%
    \textcolor{cvsecnum}{\ifnum\value{cvsec}<10 0\fi\thecvsec}%
    \hspace{0.65em}%
    #1%
  }%
  \par\vspace{2pt}%
  {\color{cvrule}\noindent\rule{\linewidth}{1.6pt}}%
  \par\vspace{8pt}%
}

\newcommand{\barsep}{\hspace{6pt}\textbar\hspace{6pt}}
\newcommand{\rowdates}[1]{\hfill{\ttfamily\small #1}}
% Small superscript outgoing-arrow icon for hyperlinked items.
\newcommand{\extarrow}{\,{\footnotesize\faExternalLink}}

\begin{document}

% ======================================================================
% HEADER
% ======================================================================
\noindent\rule{\linewidth}{2.5pt}\\[5pt]
{\noindent\ttfamily\bfseries\Huge \VAR{cv.basics.name | latex}}\\[5pt]
{\noindent\ttfamily\bfseries\small \VAR{cv.basics.role | upper | latex}}\\[7pt]
\noindent\rule{\linewidth}{0.8pt}\\[8pt]

% Contact bar (mono, dense, icon-led)
{\ttfamily\footnotesize\noindent
\faMapMarker\,\VAR{cv.basics.locationLong | latex}%
\barsep%
\faEnvelope\,\href{mailto:\VAR{cv.basics.email}}{\VAR{cv.basics.email | latex}}%
\BLOCK{ if personal_email }%
\barsep%
\faEnvelope\,\href{mailto:\VAR{personal_email}}{\VAR{personal_email | latex}}%
\BLOCK{ endif }%
\BLOCK{ if cv.basics.phone }%
\barsep%
\faPhone\,\VAR{cv.basics.phone | latex}%
\BLOCK{ endif }\\[3pt]
\faGlobe\,\href{\VAR{cv.basics.websiteUrl}}{\VAR{cv.basics.website | latex}}%
\barsep%
\faLinkedin\,\href{\VAR{cv.basics.linkedinUrl}}{\VAR{cv.basics.linkedin | latex}}%
\barsep%
\faGithub\,\href{\VAR{cv.basics.githubUrl}}{\VAR{cv.basics.github | latex}}\\[3pt]
\VAR{labels.dobAbbr | latex}\,\VAR{cv.basics.birthday | latex}%
\barsep%
\VAR{labels.licAbbr | latex}\,\VAR{cv.basics.drivingLicense | latex}%
\barsep%
\VAR{labels.statusAbbr | latex}\,\VAR{cv.basics.status | latex}
}

% ======================================================================
% SUMMARY
% ======================================================================
\cvsection{\VAR{labels.summary | upper | latex}}
\VAR{cv.basics.printSummary | latex}

% ======================================================================
% EXPERIENCE
% ======================================================================
\cvsection{\VAR{labels.experience | upper | latex}}

\BLOCK{ for item in cv.experience }
\needspace{4\baselineskip}%
\noindent\textbf{\VAR{item.role | latex}}\rowdates{\VAR{item.period | latex}}\\
{\itshape\BLOCK{ if item.link }\href{\VAR{item.link}}{\VAR{item.company | latex}\extarrow}\BLOCK{ else }\VAR{item.company | latex}\BLOCK{ endif }}\rowdates{\VAR{item.location | latex}}\\[2pt]
{\small \VAR{item.description | latex_md}}\\[8pt]
\BLOCK{ endfor }

% ======================================================================
% PROJECTS
% ======================================================================
\cvsection{\VAR{labels.projects | upper | latex}}

\BLOCK{ for proj in cv.projects }
\needspace{4\baselineskip}%
\noindent\textbf{\VAR{proj.title | latex}}\rowdates{\VAR{proj.period | latex}}\\
{\itshape \VAR{proj.subtitle | latex}}\\[2pt]
{\small \VAR{proj.description | latex}}\\[2pt]
{\ttfamily\footnotesize \VAR{proj.tags | latex_bullets}}%
\BLOCK{ if proj.links }\hfill{\footnotesize%
\BLOCK{ for link in proj.links }\href{\VAR{link.url}}{%
\BLOCK{ if link.label == 'GH' }\faGithub%
\BLOCK{ elif link.label == 'YT' }\faYoutubePlay%
\BLOCK{ elif link.label == 'HF' }{\ttfamily HF}\,{\tiny\faExternalLink}%
\BLOCK{ else }{\ttfamily \VAR{link.label | latex}}\,{\tiny\faExternalLink}%
\BLOCK{ endif }%
}\BLOCK{ if not loop.last }\hspace{8pt}\BLOCK{ endif }\BLOCK{ endfor }%
}\BLOCK{ endif }\\[8pt]
\BLOCK{ endfor }

% ======================================================================
% EDUCATION
% ======================================================================
\cvsection{\VAR{labels.education | upper | latex}}

\BLOCK{ for edu in cv.education }
\needspace{3\baselineskip}%
\noindent\textbf{\VAR{edu.degree | latex}}\rowdates{\VAR{edu.period | latex}}\\
{\itshape \VAR{edu.school | latex}}\BLOCK{ if edu.gpa }\rowdates{\VAR{labels.gpa | latex} \VAR{edu.gpa | latex}}\BLOCK{ endif }\\
\BLOCK{ if edu.note }{\small\itshape \VAR{edu.note | latex}}\\\BLOCK{ endif }
\vspace{6pt}
\BLOCK{ endfor }

% ======================================================================
% AWARDS
% ======================================================================
\cvsection{\VAR{labels.awards | upper | latex}}

\BLOCK{ for award in cv.awards }
\needspace{3\baselineskip}%
\noindent\textbf{\VAR{award.title | latex}}\BLOCK{ if award.period }\rowdates{\VAR{award.period | latex}}\BLOCK{ endif }\\
{\itshape \VAR{award.issuer | latex}}\\[2pt]
{\small \VAR{award.summary | latex}}\\[6pt]
\BLOCK{ endfor }

% ======================================================================
% COURSES
% ======================================================================
\cvsection{\VAR{labels.courses | upper | latex}}

\BLOCK{ for c in cv.courses }
\needspace{3\baselineskip}%
\noindent\textbf{\BLOCK{ if c.url }\href{\VAR{c.url}}{\VAR{c.title | latex}\extarrow}\BLOCK{ else }\VAR{c.title | latex}\BLOCK{ endif }}\rowdates{\VAR{c.issuer | latex}}\\
{\small \VAR{c.summary | latex}}\\[6pt]
\BLOCK{ endfor }

% ======================================================================
% SKILLS
% ======================================================================
\cvsection{\VAR{labels.skills | upper | latex}}

\BLOCK{ for category, items in cv.skills.items() }
\noindent{\ttfamily\bfseries\small \VAR{category | upper | latex}}\hspace{6pt}{\small \VAR{items | latex_bullets}}\\[4pt]
\BLOCK{ endfor }

\vspace{2pt}

% ======================================================================
% LANGUAGES
% ======================================================================
\cvsection{\VAR{labels.languages | upper | latex}}

\noindent\BLOCK{ for lang in cv.languages }\textbf{\VAR{lang.name | latex}} {\small (\textit{\VAR{lang.level | latex}})}\BLOCK{ if not loop.last }\hspace{18pt}\BLOCK{ endif }\BLOCK{ endfor }

% ======================================================================
% INTERESTS
% ======================================================================
\cvsection{\VAR{labels.interests | upper | latex}}

\noindent\BLOCK{ for i in cv.interests }\textbf{\VAR{i.title | latex}} {\small \textperiodcentered{} \VAR{i.desc | latex}}\BLOCK{ if not loop.last }\hspace{14pt}\BLOCK{ endif }\BLOCK{ endfor }

\vspace{14pt}

% ======================================================================
% FOOTER
% ======================================================================
\noindent\rule{\linewidth}{0.8pt}\\[4pt]
{\centering\ttfamily\footnotesize \VAR{cv.basics.footerNote | latex}\par}

\end{document}
